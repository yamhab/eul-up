build_dir = build
cxx = clang++
cxxflags = -std=c++20 -O2 -Wall -Wextra -Wpedantic
src_dir = src

rule cxx
    command = $cxx $cxxflags -c $in -o $out

rule link
    command = $cxx $in -o $out

build $build_dir/problem_0000.o: cxx $src_dir/problem_0000.cpp
build $build_dir/problem_0000: link $build_dir/problem_0000.o
